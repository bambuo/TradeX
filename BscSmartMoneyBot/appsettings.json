{
  "BotSettings": {
    "Name": "BSC Smart Money Trading Bot",
    "Version": "1.1.0",
    "DryRun": true,
    "Debug": false,
    "StateFilePath": "state/bot_state.json",
    "LogFilePath": "logs/bot.log",
    "BackupDirectory": "state/backup",

    "Monitoring": {
      "PollIntervalSeconds": 5,
      "HighVolIntervalSeconds": 3,
      "PriceCheckIntervalSeconds": 10,
      "HighVolThresholdPercent": 3.0,
      "MicrocapHighVolThresholdPercent": 5.0
    },

    "Signals": {
      "Chain": "bsc",
      "MinMarketCap": 50000,
      "MinLiquidity": 100000,
      "MaxSoldRatio": 85,
      "MinSmartMoneyWallets": 3,
      "ExcludeHoneypot": true,
      "ExcludeNewTokens": false,
      "MaxTokenAgeHours": 24
    },

    "Trading": {
      "MaxOpenPositions": 1,
      "CooldownMinutes": 30,
      "DefaultSlippage": 0.25,
      "GasLevel": "fast",
      "MaxAutoSlippage": 0.25,
      "MaxPositionSizeUSD": 50,
      "MinPositionSizeUSD": 5
    },

    "Risk": {
      "StopLossPercent": 10.0,
      "TakeProfitPercent": 50.0,
      "TrailingStopPercent": 5.0,
      "EnableTrailingStop": true,
      "IncludeFeesInPnL": true,
      "MinProfitForTrailingPercent": 15.0,
      "DynamicTrailingEnabled": true,
      "RiskLevelBuyBlock": ["CRITICAL"],
      "RiskLevelBuyPause": ["HIGH"]
    },

    "TakeProfit": {
      "PartialTakeProfitEnabled": true,
      "TargetsPercent": [20, 35, 50],
      "SellRatios": [20, 30, 50]
    },

    "Slippage": {
      "SmartSlippageEnabled": true,
      "MinSlippagePercent": 0.10,
      "MaxSlippagePercent": 0.25,
      "BaseBuySlippagePercent": 0.15,
      "BaseSellSlippagePercent": 0.15,
      "LiquidityThresholdUSD": 100000
    },

    "Fee": {
      "UseRealTimeFees": true,
      "CacheDurationSeconds": 300,
      "GasRefreshThresholdPercent": 5,
      "MinGasRefreshIntervalSeconds": 60,
      "MevProtection": true,
      "FallbackFeeUSD": 0.02
    },

    "Adaptive": {
      "DynamicPositionEnabled": true,
      "MaxRiskPerTradePercent": 1.0,
      "PositionScalingEnabled": true
    },

    "Wallet": {
      "Address": "0x8670a6ecb17cb6bcb3744898688fa6c06cce06b5",
      "MinBalanceUSDT": 10.0,
      "MinBalanceBNB": 0.01,
      "CheckBalanceBeforeTrade": true
    },

    "OnchainOS": {
      "BinaryPath": "onchainos",
      "TimeoutSeconds": 30,
      "RetryCount": 3,
      "RetryDelayMs": 1000
    }
  }
}