            builder.OpenComponent<FluentTextInput>(60);
            builder.AddAttribute(61, "Value", conditions[idx].Value);
            builder.AddAttribute(62, "ValueChanged", EventCallback.Factory.Create<string>(this, v => conditions[idx].Value = v));
            builder.CloseComponent();

            if (conditions.Count > 1)
            {
                builder.OpenComponent<FluentButton>(70);
                builder.AddAttribute(71, "Appearance", ButtonAppearance.Transparent);
                builder.AddAttribute(72, "Size", ButtonSize.Small);
                builder.AddAttribute(73, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, _ => RemoveCondition(isEntry, idx)));
                builder.AddAttribute(74, "ChildContent", (RenderFragment)(b2 => b2.AddContent(0, "×")));
                builder.CloseComponent();
            }
            else
            {
                builder.AddContent(75, "");
            }

            builder.CloseElement();
        }

        builder.OpenComponent<FluentButton>(80);
        builder.AddAttribute(81, "Appearance", ButtonAppearance.Outline);
        builder.AddAttribute(82, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, _ => AddCondition(isEntry)));
        builder.AddAttribute(83, "ChildContent", (RenderFragment)(b2 => b2.AddContent(0, "+ 添加条件")));
        builder.CloseComponent();

        builder.CloseElement();
    };

