@page "/exchanges"
@inject ExchangePageService ExchangeService
@inject ToastService ToastService

<PageTitle>交易所</PageTitle>

<section class="exchanges-page">
    <header class="page-header">
        <h2>交易所管理</h2>
        <Button Color="Color.Primary" OnClick="OpenCreate">
            添加交易所
        </Button>
    </header>

    @if (loading)
    {
        <div class="loading"><Spinner /> 加载中...</div>
    }
    else if (accounts.Count == 0)
    {
        <div class="empty-state">暂无交易所</div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var account in accounts)
            {
                var info = GetExchangeInfo(account.ExchangeType);

                var borderColor = GetExchangeColor(account.ExchangeType);

                <div class="card exchange-card" style="border-top-color: @borderColor;">
                    <div class="card-body">
                        <div class="card-header-row">
                            <div class="exchange-icon">
                                <img src="@info.IconPath" alt="@info.Label" />
                            </div>
                            <div>
                                <h3>@account.Label</h3>
                                <span class="fw-semibold small">@info.Label</span>
                            </div>
                            <div class="card-header-actions">
                                <Button Color="Color.None" OnClick="@(() => OpenEdit(account))">编辑</Button>
                                <Switch Value="@account.IsEnabled" OnValueChanged="@(value => ToggleStatusAsync(account.Id, value))" />
                            </div>
                        </div>

                        <div class="exchange-details">
                            <div class="detail-item">
                                <small class="text-muted">状态</small>
                                <span class="fw-semibold small @(account.IsEnabled ? "text-success" : "text-muted")">
                                    @(account.IsEnabled ? "启用" : "禁用")
                                </span>
                            </div>
                            <div class="detail-item">
                                <small class="text-muted">模式</small>
                                <span class="fw-semibold small">主网</span>
                            </div>
                            <div class="detail-item">
                                <small class="text-muted">测试结果</small>
                                <span class="small">@GetTestLabel(account)</span>
                            </div>
                            <div class="detail-item">
                                <small class="text-muted">资产</small>
                                @if (account.IsEnabled)
                                {
                                    if (assets.TryGetValue(account.Id, out var accountAssets))
                                    {
                                        <button type="button" class="btn btn-link btn-sm p-0" @onclick="@(() => ToggleAssets(account.Id))">
                                            @accountAssets.Count 个币种
                                        </button>
                                    }
                                    else if (assetLoading)
                                    {
                                        <span class="small">加载中...</span>
                                    }
                                    else
                                    {
                                        <Button Color="Color.None" OnClick="@(() => FetchAssetsAsync(account.Id))">加载</Button>
                                    }
                                }
                                else
                                {
                                    <span class="small">-</span>
                                }
                            </div>
                        </div>

                        @if (expandedAssets.Contains(account.Id) && assets.TryGetValue(account.Id, out var expandedItems))
                        {
                            <div class="asset-list">
                                <table class="table table-sm table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th>币种</th>
                                            <th>余额</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in expandedItems)
                                        {
                                            <tr>
                                                <td>@item.Currency</td>
                                                <td>@item.Balance.ToString("N8")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <div class="card-actions">
                            <Button IsDisabled="@(testingId == account.Id)" OnClick="@(() => TestConnectionAsync(account.Id))" class="me-1">
                                @(testingId == account.Id ? "测试中" : "测试")
                            </Button>
                            <Button OnClick="@(() => LoadOrdersAsync(account.Id, account.Label, OrderListType.Open))" class="me-1">挂单</Button>
                            <Button OnClick="@(() => LoadOrdersAsync(account.Id, account.Label, OrderListType.History))">历史</Button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@if (showOrdersDialog)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@ordersDialogTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseOrdersAsync"></button>
                </div>
                <div class="modal-body">
                    <ul class="nav nav-tabs mb-3">
                        <li class="nav-item">
                            <button class="nav-link @(ordersType == OrderListType.Open ? "active" : "")" @onclick="@(() => SwitchOrdersTab(OrderListType.Open))">当前挂单</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(ordersType == OrderListType.History ? "active" : "")" @onclick="@(() => SwitchOrdersTab(OrderListType.History))">历史订单</button>
                        </li>
                    </ul>

                    @if (ordersLoading)
                    {
                        <div class="loading"><Spinner /> 加载中...</div>
                    }
                    else if (!string.IsNullOrWhiteSpace(ordersError))
                    {
                        <div class="alert alert-danger" role="alert">@ordersError</div>
                    }
                    else
                    {
                        <table class="table table-striped table-sm orders-grid">
                            <thead>
                                <tr>
                                    <th>交易对</th>
                                    <th>方向</th>
                                    <th>类型</th>
                                    <th>状态</th>
                                    <th>价格</th>
                                    <th>数量</th>
                                    <th>已成交</th>
                                    <th>下单时间</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var o in orders)
                                {
                                    <tr>
                                        <td>@o.Pair</td>
                                        <td><span class="@(o.Side == "Buy" ? "side-buy" : "side-sell")">@(o.Side == "Buy" ? "买入" : "卖出")</span></td>
                                        <td>@FormatOrderType(o.Type)</td>
                                        <td>@FormatOrderStatus(o.Status)</td>
                                        <td>@(o.Price > 0 ? o.Price.ToString("N8") : "-")</td>
                                        <td>@o.Quantity.ToString("N8")</td>
                                        <td>@o.FilledQuantity.ToString("N8")</td>
                                        <td>@o.PlacedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (orders.Count == 0)
                        {
                            <p class="text-muted">@(ordersType == OrderListType.Open ? "暂无挂单" : "暂无历史订单")</p>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <Button Color="Color.Secondary" OnClick="CloseOrdersAsync">关闭</Button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (showFormDialog)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEdit ? "编辑交易所" : "添加交易所")</h5>
                    <button type="button" class="btn-close" @onclick="CloseFormAsync"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="form" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">名称</label>
                            <input class="form-control form-control-lg" @bind="form.Name" placeholder="名称（如：币安主账户）" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">交易所</label>
                            <select class="form-select form-select-lg" @bind="form.ExchangeType" disabled="@isEdit">
                                @foreach (var type in exchangeTypes)
                                {
                                    <option value="@type">@GetExchangeInfo(type).Label</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">API Key</label>
                            <input class="form-control form-control-lg" type="password" @bind="form.ApiKey" placeholder="@(isEdit ? "API Key（留空则不修改）" : "API Key")" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Secret Key</label>
                            <input class="form-control form-control-lg" type="password" @bind="form.SecretKey" placeholder="@(isEdit ? "Secret Key（留空则不修改）" : "Secret Key")" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Passphrase</label>
                            <input class="form-control form-control-lg" type="password" @bind="form.Passphrase" placeholder="@(isEdit ? "Passphrase（留空则不修改）" : "Passphrase（选填）")" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(formError))
                        {
                            <p class="text-danger mb-0">@formError</p>
                        }
                    </EditForm>
                </div>
                <div class="modal-footer">
                    <Button Color="Color.Primary" IsDisabled="@saving" OnClick="SaveAsync">
                        @(saving ? "保存中..." : "保存")
                    </Button>
                    <Button Color="Color.Secondary" OnClick="CloseFormAsync">取消</Button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<ExchangeItem> accounts = [];
    private Dictionary<Guid, IReadOnlyList<AssetBalanceView>> assets = [];
    private HashSet<Guid> expandedAssets = [];
    private List<ExchangeOrderDto> orders = [];
    private ExchangeFormModel form = new();
    private readonly ExchangeType[] exchangeTypes = Enum.GetValues<ExchangeType>();
    private bool loading = true;
    private bool assetLoading;
    private bool saving;
    private bool isEdit;
    private bool showFormDialog;
    private bool showOrdersDialog;
    private Guid? formExchangeId;
    private bool ordersLoading;
    private Guid? testingId;
    private string? formError;
    private string? ordersError;
    private string ordersExchangeLabel = string.Empty;
    private Guid ordersExchangeId;
    private OrderListType ordersType = OrderListType.Open;
    private string ordersDialogTitle => $"{ordersExchangeLabel} - {(ordersType == OrderListType.Open ? "当前挂单" : "历史订单")}";

    protected override async Task OnInitializedAsync()
    {
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        loading = true;
        try
        {
            var state = await AuthenticationStateTask;
            accounts = (await ExchangeService.GetAllAsync(state.User)).ToList();
            await FetchAssetsAsync();
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task FetchAssetsAsync(Guid? exchangeId = null)
    {
        if (exchangeId.HasValue)
        {
            try
            {
                assets[exchangeId.Value] = await ExchangeService.GetAssetsAsync(exchangeId.Value);
            }
            catch (Exception ex)
            {
                await ShowError($"获取资产失败: {ex.Message}");
            }

            return;
        }

        var enabled = accounts.Where(a => a.IsEnabled).ToArray();
        if (enabled.Length == 0)
        {
            return;
        }

        assetLoading = true;
        foreach (var account in enabled)
        {
            try
            {
                assets[account.Id] = await ExchangeService.GetAssetsAsync(account.Id);
            }
            catch
            {
                // 单个交易所资产加载失败不阻断页面展示。
            }
        }

        assetLoading = false;
    }

    private async Task OpenCreate()
    {
        form = new ExchangeFormModel();
        isEdit = false;
        formExchangeId = null;
        formError = null;
        showFormDialog = true;
    }

    private async Task OpenEdit(ExchangeItem account)
    {
        form = new ExchangeFormModel
        {
            Name = account.Label,
            ExchangeType = account.ExchangeType
        };
        isEdit = true;
        formExchangeId = account.Id;
        formError = null;
        showFormDialog = true;
    }

    private async Task CloseFormAsync()
    {
        showFormDialog = false;
    }

    private async Task SaveAsync()
    {
        formError = null;
        saving = true;
        try
        {
            var state = await AuthenticationStateTask;
            if (isEdit && formExchangeId.HasValue)
            {
                await ExchangeService.UpdateAsync(formExchangeId.Value, form);
            }
            else
            {
                await ExchangeService.CreateAsync(state.User, form);
            }

            showFormDialog = false;
            await ShowSuccess("交易所已保存");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ToggleStatusAsync(Guid id, bool enable)
    {
        try
        {
            await ExchangeService.ToggleAsync(id, enable);
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            await ShowError($"切换失败: {ex.Message}");
        }
    }

    private async Task TestConnectionAsync(Guid id)
    {
        testingId = id;
        try
        {
            var result = await ExchangeService.TestConnectionAsync(id);
            if (result.Connected)
            {
                await ShowInfo("连接测试成功");
            }
            else
            {
                await ShowInfo($"连接测试未通过{(string.IsNullOrWhiteSpace(result.Error) ? string.Empty : ": " + result.Error)}");
            }

            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            await ShowInfo($"连接测试请求失败: {ex.Message}");
        }
        finally
        {
            testingId = null;
        }
    }

    private async Task LoadOrdersAsync(Guid id, string label, OrderListType type)
    {
        ordersExchangeId = id;
        ordersExchangeLabel = label;
        ordersType = type;
        orders = [];
        ordersError = null;
        ordersLoading = true;
        showOrdersDialog = true;
        try
        {
            orders = (await ExchangeService.GetOrdersAsync(id, type)).ToList();
        }
        catch (Exception ex)
        {
            ordersError = $"获取订单失败: {ex.Message}";
        }
        finally
        {
            ordersLoading = false;
        }
    }

    private async Task SwitchOrdersTab(OrderListType type)
    {
        if (type != ordersType)
        {
            await LoadOrdersAsync(ordersExchangeId, ordersExchangeLabel, type);
        }
    }

    private async Task CloseOrdersAsync()
    {
        showOrdersDialog = false;
        orders = [];
        ordersError = null;
    }

    private void ToggleAssets(Guid id)
    {
        if (!expandedAssets.Add(id))
        {
            expandedAssets.Remove(id);
        }
    }

    private string GetTestLabel(ExchangeItem account)
    {
        if (testingId == account.Id)
        {
            return "测试中...";
        }

        if (string.IsNullOrWhiteSpace(account.TestResult))
        {
            return "-";
        }

        return IsTestOk(account.TestResult) ? "连接正常" : "连接异常";
    }

    private static bool IsTestOk(string testResult)
    {
        return !System.Text.RegularExpressions.Regex.IsMatch(
            testResult,
            "失败|错误|异常|无权限|error|invalid|unreachable|denied|reject|timeout|expired|HTTP \\d",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
    }

    private async Task ShowSuccess(string text)
        => await ToastService.Success("成功", text);

    private async Task ShowInfo(string text)
        => await ToastService.Information("信息", text);

    private async Task ShowError(string text)
        => await ToastService.Error("错误", text);

    private static ExchangeInfo GetExchangeInfo(ExchangeType type)
    {
        return type switch
        {
            ExchangeType.OKX => new ExchangeInfo("OKX", "OKX", "/exchanges/okx.svg"),
            ExchangeType.Gate => new ExchangeInfo("Gate.io", "G", "/exchanges/gateio.svg"),
            ExchangeType.Bybit => new ExchangeInfo("Bybit", "B", "/exchanges/bybit.svg"),
            ExchangeType.HTX => new ExchangeInfo("HTX", "H", "/exchanges/htx.svg"),
            _ => new ExchangeInfo("Binance", "B", "/exchanges/binance.svg")
        };
    }

    private static string FormatOrderType(string type)
    {
        return type switch
        {
            "Market" => "市价",
            "Limit" => "限价",
            "StopLimit" => "止损限价",
            _ => type
        };
    }

    private static string FormatOrderStatus(string status)
    {
        return status switch
        {
            "New" => "待成交",
            "PartiallyFilled" => "部分成交",
            "Filled" => "已成交",
            "Cancelled" => "已撤销",
            "Expired" => "已过期",
            _ => status
        };
    }

    private static string GetExchangeColor(ExchangeType type) => type switch
    {
        ExchangeType.OKX => "#1757e0",
        ExchangeType.Gate => "#1e6a5e",
        ExchangeType.Bybit => "#2d3748",
        ExchangeType.HTX => "#0084ff",
        _ => "#f0b90b"
    };

    private sealed record ExchangeInfo(string Label, string ShortName, string IconPath);
}
