@page "/traders/{TraderId:guid}/strategies"
@inject IStrategyPageService StrategyService
@inject NavigationManager Navigation
@inject IToastService ToastService

<PageTitle>策略部署</PageTitle>

<section>
    <header>
        <div>
            <FluentButton Appearance="ButtonAppearance.Transparent" OnClick="GoBack">
                返回
            </FluentButton>
            <FluentText As="TextTag.H2">策略部署</FluentText>
        </div>
        <FluentButton Appearance="ButtonAppearance.Primary" OnClick="OpenCreate">
            新建部署
        </FluentButton>
    </header>

    @if (loading)
    {
        <div><FluentSpinner /> 加载中...</div>
    }
    else if (deployments.Count == 0)
    {
        <div>
            <FluentText As="TextTag.Paragraph" Weight="TextWeight.Semibold">暂无策略部署</FluentText>
            <FluentText Size="TextSize.Size200">点击上方按钮创建第一个策略部署</FluentText>
        </div>
    }
    else
    {
        <FluentDataGrid Items="@deployments.AsQueryable()" Pagination="@pagination">
            <TemplateColumn Title="作用域">
                <span>@GetScopeLabel(context.Scope)</span>
            </TemplateColumn>
            <PropertyColumn Property="@(d => d.StrategyLabel)" Title="策略" />
            <PropertyColumn Property="@(d => d.ExchangeLabel)" Title="交易所" />
            <TemplateColumn Title="交易对">
                @FormatSymbolIds(context.SymbolIds)
            </TemplateColumn>
            <PropertyColumn Property="@(d => d.Timeframe)" Title="周期" />
            <TemplateColumn Title="状态">
                <span>@GetStatusLabel(context.Status)</span>
            </TemplateColumn>
            <PropertyColumn Property="@(d => d.UpdatedAt)" Title="更新时间" />
            <TemplateColumn Title="操作">
                <div>
                    <FluentButton Size="ButtonSize.Small"
                        Appearance="@(context.Status == DeploymentStatus.Active ? ButtonAppearance.Outline : ButtonAppearance.Primary)"
                        Disabled="@(context.Status == DeploymentStatus.Draft)"
                        OnClick="@(() => ToggleAsync(context.Id, context.Status != DeploymentStatus.Active))">
                        @GetToggleLabel(context.Status)
                    </FluentButton>
                    <FluentButton Size="ButtonSize.Small" Appearance="ButtonAppearance.Outline"
                        Disabled="@(context.Status == DeploymentStatus.Active)"
                        OnClick="@(() => OpenEdit(context))">
                        编辑
                    </FluentButton>
                    <FluentButton Size="ButtonSize.Small" Appearance="ButtonAppearance.Outline"
                        OnClick="@(() => Navigation.NavigateTo($"/traders/{TraderId}/strategies/{context.Id}/backtest"))">
                        回测
                    </FluentButton>
                    <FluentButton Size="ButtonSize.Small" Appearance="ButtonAppearance.Outline"
                        Disabled="@(context.Status == DeploymentStatus.Active)"
                        OnClick="@(() => DeleteAsync(context.Id))">
                        删除
                    </FluentButton>
                </div>
            </TemplateColumn>
        </FluentDataGrid>
        <FluentPaginator State="@pagination" />
    }
</section>

<FluentDialog @ref="formDialog" Modal="true">
    <FluentDialogBody>
        <TitleTemplate>
            @(isEdit ? "编辑部署" : "新建策略部署")
        </TitleTemplate>
        <ChildContent>
            <div>
                <FluentRadioGroup @bind-Value="formScope" Orientation="Orientation.Horizontal">
                    <FluentRadio Value="@("Trader")">交易员级</FluentRadio>
                    <FluentRadio Value="@("Exchange")">交易所级</FluentRadio>
                    <FluentRadio Value="@("Symbol")">交易对级</FluentRadio>
                </FluentRadioGroup>

                <FluentSelect TOption="StrategyOption" TValue="Guid"
                    Width="100%"
                    Label="策略模板"
                    Items="strategies"
                    Disabled="@isEdit"
                    OptionText="@(s => s.Name)"
                    OptionValue="@(s => s.Id)"
                    @bind-Value="formStrategyId" />

                @if (formScope != "Trader")
                {
                    <FluentSelect TOption="ExchangeOption" TValue="Guid?"
                        Width="100%"
                        Label="交易所账户"
                        Items="exchangeOptions"
                        Disabled="@isEdit"
                        OptionText="@(e => e.Name)"
                        OptionValue="@(e => (Guid?)e.Id)"
                        @bind-Value="formExchangeId" />
                }

                @if (formScope == "Symbol")
                {
                    <FluentTextInput Width="100%" Size="TextInputSize.Large" Label="交易对" Placeholder="输入交易对，逗号分隔（如 BTCUSDT,ETHUSDT）" @bind-Value="formSymbolsInput" />
                }

                <FluentSelect TOption="string" TValue="string"
                    Width="100%"
                    Label="时间周期"
                    Items="timeframes"
                    @bind-Value="formTimeframe" />

                @if (!string.IsNullOrWhiteSpace(formError))
                {
                    <FluentText As="TextTag.Paragraph">@formError</FluentText>
                }
            </div>
        </ChildContent>
        <ActionTemplate>
            <div>
                <FluentButton Appearance="ButtonAppearance.Primary" Disabled="@saving" OnClick="SaveAsync">
                    @(saving ? "保存中..." : "保存")
                </FluentButton>
                <FluentButton Appearance="ButtonAppearance.Outline" OnClick="CloseFormAsync">取消</FluentButton>
            </div>
        </ActionTemplate>
    </FluentDialogBody>
</FluentDialog>

@code {
    [Parameter]
    public Guid TraderId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<DeploymentItem> deployments = [];
    private List<StrategyOption> strategies = [];
    private List<ExchangeOption> exchangeOptions = [];
    private FluentDialog formDialog = default!;
    private PaginationState pagination = new() { ItemsPerPage = 10 };
    private bool loading = true;
    private bool saving;
    private bool isEdit;
    private Guid? editId;
    private string formScope = "Symbol";
    private Guid formStrategyId;
    private Guid? formExchangeId;
    private string formSymbolsInput = string.Empty;
    private string formTimeframe = "15m";
    private string? formError;

    private static readonly string[] timeframes = ["1m", "5m", "15m", "30m", "1h", "4h", "1d"];

    private sealed record StrategyOption(Guid Id, string Name);

    protected override async Task OnInitializedAsync()
    {
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        loading = true;
        try
        {
            var state = await AuthenticationStateTask;
            deployments = (await StrategyService.GetAllAsync(state.User, TraderId)).ToList();
            strategies = (await StrategyService.GetAllStrategiesAsync())
                .Select(s => new StrategyOption(s.Id, s.Name))
                .ToList();
            exchangeOptions = (await StrategyService.GetExchangesAsync(state.User)).ToList();
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
        finally
        {
            loading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/traders");
    }

    private async Task OpenCreate()
    {
        isEdit = false;
        editId = null;
        formScope = "Symbol";
        formStrategyId = strategies.Count > 0 ? strategies[0].Id : Guid.Empty;
        formExchangeId = exchangeOptions.Count > 0 ? exchangeOptions[0].Id : null;
        formSymbolsInput = string.Empty;
        formTimeframe = "15m";
        formError = null;
        await formDialog.ShowAsync();
    }

    private async Task OpenEdit(DeploymentItem item)
    {
        isEdit = true;
        editId = item.Id;
        formScope = item.Scope;
        formStrategyId = item.StrategyId;
        formExchangeId = item.ExchangeId != Guid.Empty ? item.ExchangeId : null;
        formSymbolsInput = FormatSymbolIds(item.SymbolIds);
        formTimeframe = item.Timeframe;
        formError = null;
        await formDialog.ShowAsync();
    }

    private async Task CloseFormAsync()
    {
        await formDialog.HideAsync();
    }

    private async Task SaveAsync()
    {
        formError = null;
        saving = true;
        try
        {
            var state = await AuthenticationStateTask;
            var exchangeId = formScope == "Trader" ? null : formExchangeId;
            var symbolIds = formScope == "Symbol"
                ? SerializeSymbolIds(formSymbolsInput)
                : "[]";

            if (isEdit && editId.HasValue)
            {
                await StrategyService.UpdateAsync(editId.Value, new StrategyDeploymentFormModel
                {
                    StrategyId = formStrategyId,
                    ExchangeId = exchangeId,
                    SymbolIds = symbolIds,
                    Timeframe = formTimeframe
                });
            }
            else
            {
                await StrategyService.CreateAsync(state.User, TraderId, new StrategyDeploymentFormModel
                {
                    StrategyId = formStrategyId,
                    ExchangeId = exchangeId,
                    SymbolIds = symbolIds,
                    Timeframe = formTimeframe
                });
            }

            await formDialog.HideAsync();
            await ShowSuccess(isEdit ? "部署已更新" : "部署已创建");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ToggleAsync(Guid id, bool enable)
    {
        try
        {
            await StrategyService.ToggleAsync(id, enable);
            await ShowSuccess(enable ? "策略已启用" : "策略已禁用");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        try
        {
            await StrategyService.DeleteAsync(id);
            await ShowSuccess("部署已删除");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
    }

    private static string GetScopeLabel(string scope) => scope switch
    {
        "Trader" => "交易员级",
        "Exchange" => "交易所级",
        "Symbol" => "交易对级",
        _ => scope
    };

    private static string GetStatusLabel(DeploymentStatus status) => status switch
    {
        DeploymentStatus.Draft => "草稿",
        DeploymentStatus.Backtesting => "回测中",
        DeploymentStatus.Passed => "已通过",
        DeploymentStatus.Active => "活跃",
        DeploymentStatus.Disabled => "已禁用",
        _ => status.ToString()
    };

    private static string GetToggleLabel(DeploymentStatus status) => status switch
    {
        DeploymentStatus.Active => "禁用",
        _ => "启用"
    };

    private static string FormatSymbolIds(string symbolIds)
    {
        if (string.IsNullOrWhiteSpace(symbolIds) || symbolIds == "[]")
            return "-";
        try
        {
            var parsed = System.Text.Json.JsonSerializer.Deserialize<string[]>(symbolIds);
            return parsed is { Length: > 0 } ? string.Join(", ", parsed) : "-";
        }
        catch
        {
            return symbolIds;
        }
    }

    private static string SerializeSymbolIds(string input)
    {
        if (string.IsNullOrWhiteSpace(input))
            return "[]";
        var parts = input.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return System.Text.Json.JsonSerializer.Serialize(parts);
    }

    private async Task ShowSuccess(string text)
        => await ToastService.ShowToastAsync(o => { o.Body = text; o.Intent = ToastIntent.Success; o.Timeout = 3000; });

    private async Task ShowError(string text)
        => await ToastService.ShowToastAsync(o => { o.Body = text; o.Intent = ToastIntent.Error; });
}
