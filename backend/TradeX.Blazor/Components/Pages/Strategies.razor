@page "/traders/{TraderId:guid}/strategies"
@inject IStrategyPageService StrategyService
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>策略部署</PageTitle>

<section class="strategies-page">
    <header class="page-header">
        <div class="header-left">
            <Button Color="Color.None" OnClick="GoBack">
                返回
            </Button>
            <h2>策略部署</h2>
        </div>
        <Button Color="Color.Primary" OnClick="OpenCreate">
            新建部署
        </Button>
    </header>

    @if (loading)
    {
        <div class="loading"><Spinner /> 加载中...</div>
    }
    else if (bindings.Count == 0)
    {
        <div class="empty-state">
            <p class="fw-semibold">暂无策略部署</p>
            <small class="text-muted">点击上方按钮创建第一个策略部署</small>
        </div>
    }
    else
    {
        <table class="table table-striped strategies-grid">
            <thead>
                <tr>
                    <th>作用域</th>
                    <th>策略</th>
                    <th>交易所</th>
                    <th>交易对</th>
                    <th>周期</th>
                    <th>状态</th>
                    <th>更新时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in bindings)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@GetScopeLabel(d.Scope)</span></td>
                        <td>@d.StrategyLabel</td>
                        <td>@d.ExchangeLabel</td>
                        <td>@FormatPairs(d.Pairs)</td>
                        <td>@d.Timeframe</td>
                        <td><span class="badge @GetStatusBadgeClass(d.Status)">@GetStatusLabel(d.Status)</span></td>
                        <td>@d.UpdatedAt</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <Button Size="Size.Small"
                                    Color="@(d.Status == BindingStatus.Active ? Color.Warning : Color.Primary)"
                                    IsDisabled="@false"
                                    OnClick="@(() => ToggleAsync(d.Id, d.Status != BindingStatus.Active))">
                                    @GetToggleLabel(d.Status)
                                </Button>
                                <Button Size="Size.Small" Color="Color.Secondary"
                                    IsDisabled="@(d.Status == BindingStatus.Active)"
                                    OnClick="@(() => OpenEdit(d))">
                                    编辑
                                </Button>
                                <Button Size="Size.Small" Color="Color.Secondary"
                                    OnClick="@(() => Navigation.NavigateTo($"/traders/{TraderId}/strategies/{d.Id}/backtest"))">
                                    回测
                                </Button>
                                <Button Size="Size.Small" Color="Color.Danger"
                                    IsDisabled="@(d.Status == BindingStatus.Active)"
                                    OnClick="@(() => DeleteAsync(d.Id))">
                                    删除
                                </Button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@if (showDialog)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEdit ? "编辑部署" : "新建策略部署")</h5>
                    <button type="button" class="btn-close" @onclick="CloseFormAsync"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">作用域</label>
                        <div class="btn-group w-100" role="group">
                            @foreach (var scope in new[] { "Trader", "Exchange", "Pair" })
                            {
                                <button type="button" class="btn @(formScope == scope ? "btn-primary" : "btn-outline-primary")"
                                    @onclick="() => formScope = scope">
                                    @(scope switch { "Trader" => "交易员级", "Exchange" => "交易所级", _ => "交易对级" })
                                </button>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">策略模板</label>
                        <select class="form-select" @bind="formStrategyId" disabled="@isEdit">
                            @foreach (var s in strategies)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>

                    @if (formScope != "Trader")
                    {
                        <div class="mb-3">
                            <label class="form-label">交易所账户</label>
                            <select class="form-select" @bind="formExchangeId" disabled="@isEdit">
                                @foreach (var e in exchangeOptions)
                                {
                                    <option value="@e.Id">@e.Name</option>
                                }
                            </select>
                        </div>
                    }

                    @if (formScope == "Pair")
                    {
                        <div class="mb-3">
                            <label class="form-label">交易对</label>
                            <input class="form-control form-control-lg" @bind="formPairsInput" placeholder="输入交易对，逗号分隔（如 BTCUSDT,ETHUSDT）" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">时间周期</label>
                        <select class="form-select" @bind="formTimeframe">
                            @foreach (var tf in timeframes)
                            {
                                <option value="@tf">@tf</option>
                            }
                        </select>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <p class="text-danger mb-0">@formError</p>
                    }
                </div>
                <div class="modal-footer">
                    <Button Color="Color.Primary" IsDisabled="@saving" OnClick="SaveAsync">
                        @(saving ? "保存中..." : "保存")
                    </Button>
                    <Button Color="Color.Secondary" OnClick="CloseFormAsync">取消</Button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public Guid TraderId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<BindingItem> bindings = [];
    private List<StrategyOption> strategies = [];
    private List<ExchangeOption> exchangeOptions = [];
    private bool loading = true;
    private bool saving;
    private bool showDialog;
    private bool isEdit;
    private Guid? editId;
    private string formScope = "Pair";
    private Guid formStrategyId;
    private Guid? formExchangeId;
    private string formPairsInput = string.Empty;
    private string formTimeframe = "15m";
    private string? formError;

    private static readonly string[] timeframes = ["1m", "5m", "15m", "30m", "1h", "4h", "1d"];

    private sealed record StrategyOption(Guid Id, string Name);

    protected override async Task OnInitializedAsync()
    {
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        loading = true;
        try
        {
            var state = await AuthenticationStateTask;
            bindings = (await StrategyService.GetAllAsync(state.User, TraderId)).ToList();
            strategies = (await StrategyService.GetAllStrategiesAsync())
                .Select(s => new StrategyOption(s.Id, s.Name))
                .ToList();
            exchangeOptions = (await StrategyService.GetExchangesAsync(state.User)).ToList();
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
        finally
        {
            loading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/traders");
    }

    private async Task OpenCreate()
    {
        isEdit = false;
        editId = null;
        formScope = "Pair";
        formStrategyId = strategies.Count > 0 ? strategies[0].Id : Guid.Empty;
        formExchangeId = exchangeOptions.Count > 0 ? exchangeOptions[0].Id : null;
        formPairsInput = string.Empty;
        formTimeframe = "15m";
        formError = null;
        showDialog = true;
    }

    private async Task OpenEdit(BindingItem item)
    {
        isEdit = true;
        editId = item.Id;
        formScope = item.Scope;
        formStrategyId = item.StrategyId;
        formExchangeId = item.ExchangeId != Guid.Empty ? item.ExchangeId : null;
        formPairsInput = FormatPairs(item.Pairs);
        formTimeframe = item.Timeframe;
        formError = null;
        showDialog = true;
    }

    private async Task CloseFormAsync()
    {
        showDialog = false;
    }

    private async Task SaveAsync()
    {
        formError = null;
        saving = true;
        try
        {
            var state = await AuthenticationStateTask;
            var exchangeId = formScope == "Trader" ? null : formExchangeId;
            var pairs = formScope == "Pair"
                ? SerializePairs(formPairsInput)
                : "[]";

            if (isEdit && editId.HasValue)
            {
                await StrategyService.UpdateAsync(editId.Value, new StrategyBindingFormModel
                {
                    StrategyId = formStrategyId,
                    ExchangeId = exchangeId,
                    Pairs = pairs,
                    Timeframe = formTimeframe
                });
            }
            else
            {
                await StrategyService.CreateAsync(state.User, TraderId, new StrategyBindingFormModel
                {
                    StrategyId = formStrategyId,
                    ExchangeId = exchangeId,
                    Pairs = pairs,
                    Timeframe = formTimeframe
                });
            }

            showDialog = false;
            await ShowSuccess(isEdit ? "部署已更新" : "部署已创建");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ToggleAsync(Guid id, bool enable)
    {
        try
        {
            await StrategyService.ToggleAsync(id, enable);
            await ShowSuccess(enable ? "策略已启用" : "策略已禁用");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        try
        {
            await StrategyService.DeleteAsync(id);
            await ShowSuccess("部署已删除");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
    }

    private static string GetScopeLabel(string scope) => scope switch
    {
        "Trader" => "交易员级",
        "Exchange" => "交易所级",
        "Pair" => "交易对级",
        _ => scope
    };

    private static string GetStatusLabel(BindingStatus status) => status switch
    {
        BindingStatus.Draft => "草稿",
        BindingStatus.Backtesting => "回测中",
        BindingStatus.Passed => "已通过",
        BindingStatus.Active => "活跃",
        BindingStatus.Disabled => "已禁用",
        _ => status.ToString()
    };

    private static string GetStatusBadgeClass(BindingStatus status) => status switch
    {
        BindingStatus.Draft => "bg-secondary",
        BindingStatus.Backtesting => "bg-info",
        BindingStatus.Passed => "bg-success",
        BindingStatus.Active => "bg-primary",
        BindingStatus.Disabled => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string GetToggleLabel(BindingStatus status) => status switch
    {
        BindingStatus.Active => "禁用",
        _ => "启用"
    };

    private static string FormatPairs(string pairs)
    {
        if (string.IsNullOrWhiteSpace(pairs) || pairs == "[]")
            return "-";
        try
        {
            var parsed = System.Text.Json.JsonSerializer.Deserialize<string[]>(pairs);
            return parsed is { Length: > 0 } ? string.Join(", ", parsed) : "-";
        }
        catch
        {
            return pairs;
        }
    }

    private static string SerializePairs(string input)
    {
        if (string.IsNullOrWhiteSpace(input))
            return "[]";
        var parts = input.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return System.Text.Json.JsonSerializer.Serialize(parts);
    }

    private async Task ShowSuccess(string text)
        => await ToastService.Success("成功", text);

    private async Task ShowError(string text)
        => await ToastService.Error("错误", text);
}
