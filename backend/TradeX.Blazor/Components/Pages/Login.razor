@page "/login"
@inject AuthWorkflowService AuthWorkflow
@inject AuthSession Session
@inject AuthTicketStore TicketStore
@inject NavigationManager Navigation

<PageTitle>登录 TradeX</PageTitle>

<main class="login-container">
    <div class="card login-form">
        <div class="card-body">
            @if (step == LoginStep.Login)
            {
                <EditForm Model="loginForm" OnValidSubmit="LoginAsync" class="login-form-content">
                    <DataAnnotationsValidator />
                    <h1 class="login-title">TradeX</h1>
                    <p class="login-subtitle">多交易所现货交易系统</p>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <p class="login-error" role="alert">@errorMessage</p>
                    }

                    <label class="login-field">
                        <input class="form-control form-control-lg w-100" @bind="loginForm.UserName" autocomplete="username" placeholder="用户名" />
                        <ValidationMessage For="@(() => loginForm.UserName)" />
                    </label>

                    <label class="login-field">
                        <input class="form-control form-control-lg w-100" type="password" @bind="loginForm.Password" autocomplete="current-password" placeholder="密码" />
                        <ValidationMessage For="@(() => loginForm.Password)" />
                    </label>

                    <Button Size="Size.Large" ButtonType="ButtonType.Submit" Color="Color.Primary" IsDisabled="@isLoading" class="login-button w-100">
                        @(isLoading ? "登录中..." : "登录")
                    </Button>
                </EditForm>
            }
            else if (step == LoginStep.MfaSetup)
            {
                <EditForm Model="mfaForm" OnValidSubmit="VerifyMfaSetupAsync" class="login-form-content">
                    <DataAnnotationsValidator />
                    <h1 class="login-title">绑定双重认证</h1>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <p class="login-error" role="alert">@errorMessage</p>
                    }

                    @if (mfaSetup is null)
                    {
                        <div class="login-loading-state">
                            <Progress IsIndeterminate="true" />
                            <p class="login-loading-text">正在获取 MFA 配置...</p>
                        </div>
                    }
                    else
                    {
                        <p class="login-subtitle">使用身份验证器应用扫描以下二维码：</p>
                        <div class="qr-section">
                            <img class="qr" src="@mfaSetup.QrCodeImage" alt="MFA 绑定二维码" />
                            <div class="secret-box">
                                <span>密钥：</span>
                                <code>@mfaSetup.SecretKey</code>
                            </div>
                        </div>

                        <p class="login-subtitle">扫描完成后，输入应用中的 6 位验证码：</p>

                        <label class="login-field">
                            <input class="form-control form-control-lg w-100" @bind="mfaForm.Code" maxlength="6" autocomplete="one-time-code" placeholder="6 位验证码" />
                            <ValidationMessage For="@(() => mfaForm.Code)" />
                        </label>

                        <Button Size="Size.Large" ButtonType="ButtonType.Submit" Color="Color.Primary" IsDisabled="@isLoading" class="login-button w-100">
                            @(isLoading ? "验证中..." : "确认并绑定")
                        </Button>
                    }
                </EditForm>
            }
            else
            {
                <EditForm Model="mfaForm" OnValidSubmit="VerifyMfaAsync" class="login-form-content">
                    <DataAnnotationsValidator />
                    <h1 class="login-title">@(step == LoginStep.Recovery ? "恢复码验证" : "MFA 验证")</h1>
                    <p class="login-subtitle">@(step == LoginStep.Recovery ? "输入一个恢复码（格式：XXXX-XXXX）" : "请输入身份验证器中的 6 位代码")</p>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <p class="login-error" role="alert">@errorMessage</p>
                    }

                    @if (step == LoginStep.Recovery)
                    {
                        <label class="login-field">
                            <input class="form-control form-control-lg w-100" @bind="mfaForm.RecoveryCode" autocomplete="one-time-code" placeholder="XXXX-XXXX" />
                        </label>
                    }
                    else
                    {
                        <label class="login-field">
                            <input class="form-control form-control-lg w-100" @bind="mfaForm.Code" maxlength="6" autocomplete="one-time-code" placeholder="6 位验证码" />
                        </label>
                    }

                    <Button Size="Size.Large" ButtonType="ButtonType.Submit" Color="Color.Primary" IsDisabled="@isLoading" class="login-button w-100">
                        @(isLoading ? "验证中..." : "验证")
                    </Button>
                    <Button Size="Size.Large" Color="Color.None" OnClick="ToggleRecoveryMode" class="login-text-button w-100">
                        @(step == LoginStep.Recovery ? "使用 TOTP 验证码" : "使用恢复码")
                    </Button>
                </EditForm>
            }
        </div>
    </div>
</main>

@code {
    private readonly LoginForm loginForm = new();
    private readonly MfaForm mfaForm = new();
    private LoginStep step = LoginStep.Login;
    private MfaSetupResponse? mfaSetup;
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var status = await AuthWorkflow.GetSetupStatusAsync();
            if (!status.IsInitialized)
            {
                Navigation.NavigateTo("/setup", replace: true);
            }
        }
        catch
        {
            // 登录提交时会给出明确错误；初始化检查失败不阻断页面展示。
        }
    }

    private async Task LoginAsync()
    {
        errorMessage = null;
        isLoading = true;

        try
        {
            var result = await AuthWorkflow.LoginAsync(new LoginRequest(loginForm.UserName, loginForm.Password));
            if (!string.IsNullOrWhiteSpace(result.MfaToken))
            {
                Session.SetMfaToken(result.MfaToken);
            }

            if (result.MfaSetupRequired)
            {
                step = LoginStep.MfaSetup;
                mfaSetup = await AuthWorkflow.SetupMfaAsync(Session.MfaToken!);
                return;
            }

            step = LoginStep.Mfa;
        }
        catch (Exception ex) when (ex is UnauthorizedAccessException or InvalidOperationException)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task VerifyMfaSetupAsync()
    {
        errorMessage = null;
        isLoading = true;

        try
        {
            var tokens = await AuthWorkflow.VerifyMfaSetupAsync(Session.MfaToken!, mfaForm.Code);
            CompleteSignIn(tokens);
        }
        catch (Exception ex) when (ex is UnauthorizedAccessException or InvalidOperationException)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task VerifyMfaAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.MfaToken))
        {
            errorMessage = "登录会话已过期，请重新输入用户名和密码。";
            step = LoginStep.Login;
            return;
        }

        errorMessage = null;
        isLoading = true;

        try
        {
            var tokens = await AuthWorkflow.VerifyMfaAsync(
                Session.MfaToken,
                step == LoginStep.Mfa ? mfaForm.Code : null,
                step == LoginStep.Recovery ? mfaForm.RecoveryCode : null);
            CompleteSignIn(tokens);
        }
        catch (Exception ex) when (ex is UnauthorizedAccessException or InvalidOperationException)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleRecoveryMode()
    {
        errorMessage = null;
        step = step == LoginStep.Recovery ? LoginStep.Mfa : LoginStep.Recovery;
    }

    private void CompleteSignIn(AuthTokens tokens)
    {
        Session.Clear();
        var ticket = TicketStore.Issue(tokens);
        Navigation.NavigateTo($"/auth/complete?ticket={Uri.EscapeDataString(ticket)}", forceLoad: true);
    }

    private enum LoginStep
    {
        Login,
        Mfa,
        MfaSetup,
        Recovery
    }

    private sealed class LoginForm
    {
        [Required(ErrorMessage = "请输入用户名")]
        public string UserName { get; set; } = string.Empty;

        [Required(ErrorMessage = "请输入密码")]
        public string Password { get; set; } = string.Empty;
    }

    private sealed class MfaForm
    {
        [Required(ErrorMessage = "请输入验证码")]
        public string Code { get; set; } = string.Empty;

        public string RecoveryCode { get; set; } = string.Empty;
    }
}
