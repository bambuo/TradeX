@page "/setup"
@inject AuthWorkflowService AuthWorkflow
@inject NavigationManager Navigation

<PageTitle>初始化 TradeX</PageTitle>

<main>
    <FluentCard>
        @if (step == SetupStep.Checking)
        {
            <div>
                <FluentProgressBar Indeterminate="true" />
                <FluentText As="TextTag.Paragraph">正在检查系统初始化状态...</FluentText>
            </div>
        }
        else if (step == SetupStep.Success)
        {
            <div>
                <div>✓</div>
                <FluentText As="TextTag.H2">初始化成功！</FluentText>
                <FluentText As="TextTag.Paragraph">系统已创建 Super Admin 账户，请继续登录并绑定 MFA。</FluentText>
                <FluentButton Size="ButtonSize.Large" Appearance="ButtonAppearance.Primary" OnClick="GoToLogin">
                    前往登录
                </FluentButton>
            </div>
        }
        else
        {
            <EditForm Model="form" OnValidSubmit="InitializeAsync">
                <DataAnnotationsValidator />
                <FluentText As="TextTag.H1">TradeX 初始化</FluentText>
                <FluentText As="TextTag.Paragraph">首次部署，请创建 Super Admin 账户</FluentText>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <FluentText As="TextTag.Paragraph" role="alert">@errorMessage</FluentText>
                }

                <label>
                    <FluentTextInput Width="100%" Size="TextInputSize.Large" @bind-Value="form.UserName" AutoComplete="username" Placeholder="Super Admin 用户名" />
                    <ValidationMessage For="@(() => form.UserName)" />
                </label>

                <label>
                    <FluentTextInput Width="100%" Size="TextInputSize.Large" TextInputType="TextInputType.Password" @bind-Value="form.Password" AutoComplete="new-password" Placeholder="密码 (至少 8 位)" />
                    <ValidationMessage For="@(() => form.Password)" />
                </label>

                <label>
                    <FluentTextInput Width="100%" Size="TextInputSize.Large" TextInputType="TextInputType.Password" @bind-Value="form.ConfirmPassword" AutoComplete="new-password" Placeholder="确认密码" />
                    <ValidationMessage For="@(() => form.ConfirmPassword)" />
                </label>

                <FluentButton Size="ButtonSize.Large" Type="ButtonType.Submit" Appearance="ButtonAppearance.Primary" Disabled="@isLoading">
                    @(isLoading ? "初始化中..." : "初始化系统")
                </FluentButton>
            </EditForm>
        }
    </FluentCard>
</main>

@code {
    private readonly SetupForm form = new();
    private SetupStep step = SetupStep.Checking;
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var status = await AuthWorkflow.GetSetupStatusAsync();
            if (status.IsInitialized)
            {
                Navigation.NavigateTo("/login", replace: true);
                return;
            }
        }
        catch
        {
            // 后端未启动时仍显示表单，让用户能看到下一步入口与错误反馈。
        }

        step = SetupStep.Form;
    }

    private async Task InitializeAsync()
    {
        errorMessage = null;
        isLoading = true;

        try
        {
            await AuthWorkflow.InitializeAsync(new InitializeRequest(form.UserName, form.Password));
            step = SetupStep.Success;
        }
        catch (Exception ex) when (ex is InvalidOperationException)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private enum SetupStep
    {
        Checking,
        Form,
        Success
    }

    private sealed class SetupForm
    {
        [Required(ErrorMessage = "请输入用户名")]
        [MinLength(3, ErrorMessage = "用户名至少 3 个字符")]
        public string UserName { get; set; } = string.Empty;

        [Required(ErrorMessage = "请输入密码")]
        [MinLength(8, ErrorMessage = "密码至少 8 位")]
        public string Password { get; set; } = string.Empty;

        [Compare(nameof(Password), ErrorMessage = "两次密码输入不一致")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
