@page "/setup"
@inject AuthWorkflowService AuthWorkflow
@inject NavigationManager Navigation

<PageTitle>初始化 TradeX</PageTitle>

<main class="setup-page">
    <div class="card setup-card">
        <div class="card-body">
            @if (step == SetupStep.Checking)
            {
                <div class="setup-state">
                    <Progress IsIndeterminate="true" />
                    <p class="setup-state-text">正在检查系统初始化状态...</p>
                </div>
            }
            else if (step == SetupStep.Success)
            {
                <div class="setup-state success-state">
                    <div class="setup-success-icon">✓</div>
                    <h2 class="setup-state-title">初始化成功！</h2>
                    <p class="setup-state-text">系统已创建 Super Admin 账户，请继续登录并绑定 MFA。</p>
                    <Button Size="Size.Large" Color="Color.Primary" OnClick="GoToLogin" class="setup-submit">
                        前往登录
                    </Button>
                </div>
            }
            else
            {
                <EditForm Model="form" OnValidSubmit="InitializeAsync" class="setup-form">
                    <DataAnnotationsValidator />
                    <h1 class="setup-title">TradeX 初始化</h1>
                    <p class="setup-subtitle">首次部署，请创建 Super Admin 账户</p>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <p class="text-danger" role="alert">@errorMessage</p>
                    }

                    <label class="setup-field">
                        <input class="form-control form-control-lg w-100" @bind="form.UserName" autocomplete="username" placeholder="Super Admin 用户名" />
                        <ValidationMessage For="@(() => form.UserName)" />
                    </label>

                    <label class="setup-field">
                        <input class="form-control form-control-lg w-100" type="password" @bind="form.Password" autocomplete="new-password" placeholder="密码 (至少 8 位)" />
                        <ValidationMessage For="@(() => form.Password)" />
                    </label>

                    <label class="setup-field">
                        <input class="form-control form-control-lg w-100" type="password" @bind="form.ConfirmPassword" autocomplete="new-password" placeholder="确认密码" />
                        <ValidationMessage For="@(() => form.ConfirmPassword)" />
                    </label>

                    <Button Size="Size.Large" ButtonType="ButtonType.Submit" Color="Color.Primary" IsDisabled="@isLoading" class="setup-submit w-100">
                        @(isLoading ? "初始化中..." : "初始化系统")
                    </Button>
                </EditForm>
            }
        </div>
    </div>
</main>

@code {
    private readonly SetupForm form = new();
    private SetupStep step = SetupStep.Checking;
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var status = await AuthWorkflow.GetSetupStatusAsync();
            if (status.IsInitialized)
            {
                Navigation.NavigateTo("/login", replace: true);
                return;
            }
        }
        catch
        {
            // 后端未启动时仍显示表单，让用户能看到下一步入口与错误反馈。
        }

        step = SetupStep.Form;
    }

    private async Task InitializeAsync()
    {
        errorMessage = null;
        isLoading = true;

        try
        {
            await AuthWorkflow.InitializeAsync(new InitializeRequest(form.UserName, form.Password));
            step = SetupStep.Success;
        }
        catch (Exception ex) when (ex is InvalidOperationException)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private enum SetupStep
    {
        Checking,
        Form,
        Success
    }

    private sealed class SetupForm
    {
        [Required(ErrorMessage = "请输入用户名")]
        [MinLength(3, ErrorMessage = "用户名至少 3 个字符")]
        public string UserName { get; set; } = string.Empty;

        [Required(ErrorMessage = "请输入密码")]
        [MinLength(8, ErrorMessage = "密码至少 8 位")]
        public string Password { get; set; } = string.Empty;

        [Compare(nameof(Password), ErrorMessage = "两次密码输入不一致")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
