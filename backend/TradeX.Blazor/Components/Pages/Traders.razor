@page "/traders"
@inject ITraderPageService TraderService
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>交易员</PageTitle>

<section class="traders-page">
    <header class="page-header">
        <h2>交易员管理</h2>
        <Button Color="Color.Primary" OnClick="OpenCreate">
            新建交易员
        </Button>
    </header>

    @if (loading)
    {
        <div class="loading"><Spinner /> 加载中...</div>
    }
    else if (traders.Count == 0)
    {
        <div class="empty-state">
            <p class="fw-semibold">暂无交易员</p>
            <small class="text-muted">点击上方按钮创建第一个交易员</small>
        </div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var trader in traders)
            {
                var isActive = trader.Status == TraderStatus.Active;
                var avatarColor = GetAvatarColorFromName(trader.Name);

                <div class="card trader-card" style="border-top-color: @avatarColor;">
                    <div class="card-body">
                        <div class="card-header-row">
                            <Avatar Name="@trader.Name" />
                            <div class="card-title-area">
                                <h3>@trader.Name</h3>
                                <span class="fw-semibold small @(isActive ? "text-success" : "text-muted")">
                                    @GetStatusLabel(trader.Status)
                                </span>
                            </div>
                            <div class="card-header-actions">
                                <Button Color="Color.None" OnClick="@(() => OpenEdit(trader))">编辑</Button>
                                <Switch Value="@isActive" OnValueChanged="@(value => ToggleStatusAsync(trader.Id, value))" />
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(trader.Style))
                        {
                            <div class="trader-style">
                                <span class="badge bg-info">@trader.Style</span>
                            </div>
                        }

                        @if (traderStats.TryGetValue(trader.Id, out var stats))
                        {
                            <div class="stats-row">
                                <div class="stat-item">
                                    <strong>@stats.TotalTrades</strong>
                                    <small>交易次数</small>
                                </div>
                                <div class="stat-item">
                                    <strong>@stats.WinRate%</strong>
                                    <small>胜率</small>
                                </div>
                                <div class="stat-item">
                                    <strong>@stats.ProfitLossRatio.ToString("F2")</strong>
                                    <small>盈亏比</small>
                                </div>
                                <div class="stat-item">
                                    <strong>@stats.SharpeRatio.ToString("F2")</strong>
                                    <small>夏普率</small>
                                </div>
                            </div>
                        }

                        <div class="card-actions">
                            <Button OnClick="@(() => Navigation.NavigateTo($"/traders/{trader.Id}/strategies"))" class="me-1">策略部署</Button>
                            <Button OnClick="@(() => Navigation.NavigateTo($"/traders/{trader.Id}/positions"))" class="me-1">持仓</Button>
                            <Button OnClick="@(() => Navigation.NavigateTo($"/traders/{trader.Id}/orders"))">订单</Button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@if (showDialog)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEdit ? "编辑交易员" : "新建交易员")</h5>
                    <button type="button" class="btn-close" @onclick="CloseFormAsync"></button>
                </div>
                <div class="modal-body">
                    <div class="form-preview mb-3">
                        <Avatar Name="@(string.IsNullOrWhiteSpace(formName) ? "?" : formName[..1].ToUpperInvariant())" />
                        <div class="form-meta ms-2 d-inline-block">
                            <p class="fw-semibold mb-0">@(string.IsNullOrWhiteSpace(formName) ? "新交易员" : formName)</p>
                            <small class="text-muted">设置名称和头像</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">名称</label>
                        <input class="form-control form-control-lg" @bind="formName" placeholder="输入交易员名称" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">交易风格</label>
                        <select class="form-select form-select-lg" @bind="formStyle">
                            <option value="">请选择</option>
                            @foreach (var opt in styleOptions)
                            {
                                <option value="@opt">@opt</option>
                            }
                        </select>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <p class="text-danger mb-0">@formError</p>
                    }
                </div>
                <div class="modal-footer">
                    <Button Color="Color.Primary" IsDisabled="@saving" OnClick="SaveAsync">
                        @(saving ? "保存中..." : "保存")
                    </Button>
                    <Button Color="Color.Secondary" OnClick="CloseFormAsync">取消</Button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<TraderItem> traders = [];
    private Dictionary<Guid, TraderStatsView> traderStats = [];
    private bool loading = true;
    private bool saving;
    private bool showDialog;
    private bool isEdit;
    private Guid? editId;
    private string formName = string.Empty;
    private string formStyle = string.Empty;
    private string? formError;

    private static readonly string[] AvatarPalette =
    [
        "#4f7ec9", "#528a60", "#b8893a", "#bf4848",
        "#7c6eb0", "#c97b4a", "#4a9ea0", "#b06e8a"
    ];

    private static readonly string[] styleOptions =
    [
        "稳健型", "激进型", "平衡型", "灵活型"
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        loading = true;
        try
        {
            var state = await AuthenticationStateTask;
            traders = (await TraderService.GetAllAsync(state.User)).ToList();

            foreach (var trader in traders)
            {
                try
                {
                    var stats = await TraderService.GetStatsAsync(trader.Id);
                    traderStats[trader.Id] = stats;
                }
                catch
                {
                    // 单个交易员统计加载失败不阻断页面
                }
            }
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OpenCreate()
    {
        isEdit = false;
        editId = null;
        formName = string.Empty;
        formStyle = string.Empty;
        formError = null;
        showDialog = true;
    }

    private async Task OpenEdit(TraderItem trader)
    {
        isEdit = true;
        editId = trader.Id;
        formName = trader.Name;
        formStyle = trader.Style ?? string.Empty;
        formError = null;
        showDialog = true;
    }

    private async Task CloseFormAsync()
    {
        showDialog = false;
    }

    private async Task SaveAsync()
    {
        formError = null;
        saving = true;
        try
        {
            var state = await AuthenticationStateTask;

            if (isEdit && editId.HasValue)
            {
                await TraderService.UpdateAsync(editId.Value, new TraderFormModel
                {
                    Name = formName,
                    Style = string.IsNullOrWhiteSpace(formStyle) ? null : formStyle,
                    AvatarColor = GetAvatarColorFromName(formName)
                });
            }
            else
            {
                await TraderService.CreateAsync(state.User, new TraderFormModel
                {
                    Name = formName,
                    Style = string.IsNullOrWhiteSpace(formStyle) ? null : formStyle,
                    AvatarColor = GetAvatarColorFromName(formName)
                });
            }

            showDialog = false;
            await ShowSuccess(isEdit ? "交易员已更新" : "交易员已创建");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ToggleStatusAsync(Guid id, bool enable)
    {
        try
        {
            await TraderService.ToggleAsync(id, enable);
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            await ShowError($"切换失败: {ex.Message}");
        }
    }

    private static string GetAvatarColorFromName(string name)
    {
        var hash = 0;
        foreach (var c in name)
            hash = c + ((hash << 5) - hash);
        return AvatarPalette[Math.Abs(hash) % AvatarPalette.Length];
    }

    private static string GetStatusLabel(TraderStatus status) => status switch
    {
        TraderStatus.Active => "在岗",
        TraderStatus.Disabled => "离岗",
        TraderStatus.Deleted => "已删除",
        _ => status.ToString()
    };

    private async Task ShowSuccess(string text)
        => await ToastService.Success("成功", text);

    private async Task ShowError(string text)
        => await ToastService.Error("错误", text);
}
