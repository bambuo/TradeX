@page "/traders"
@inject ITraderPageService TraderService
@inject NavigationManager Navigation
@inject IToastService ToastService

<PageTitle>交易员</PageTitle>

<section>
    <header>
        <FluentText As="TextTag.H2">交易员管理</FluentText>
        <FluentButton Appearance="ButtonAppearance.Primary" OnClick="OpenCreate">
            新建交易员
        </FluentButton>
    </header>

    @if (loading)
    {
        <div><FluentSpinner /> 加载中...</div>
    }
    else if (traders.Count == 0)
    {
        <div>
            <FluentText As="TextTag.Paragraph" Weight="TextWeight.Semibold">暂无交易员</FluentText>
            <FluentText Size="TextSize.Size200">点击上方按钮创建第一个交易员</FluentText>
        </div>
    }
    else
    {
        <div>
            @foreach (var trader in traders)
            {
                var isActive = trader.Status == TraderStatus.Active;

                <FluentCard>
                    <div>
                        <FluentAvatar Initials="@trader.Name[..1].ToUpperInvariant()" Src="@trader.AvatarUrl" /> 
                        <div>
                            <FluentText As="TextTag.H3">@trader.Name</FluentText>
                            <FluentText As="TextTag.Span" Size="TextSize.Size200" Weight="TextWeight.Semibold">
                                @GetStatusLabel(trader.Status)
                            </FluentText>
                        </div>
                        <div>
                            <FluentButton Appearance="ButtonAppearance.Transparent" IconStart="@Icon.FromImageUrl("/exchanges/edit.svg")" IconOnly="true" Tooltip="编辑" OnClick="@(() => OpenEdit(trader))" />
                            <FluentSwitch Value="@isActive" ValueChanged="@(value => ToggleStatusAsync(trader.Id, value))" />
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(trader.Style))
                    {
                        <div>
                            <span>@trader.Style</span>
                        </div>
                    }

                    @if (traderStats.TryGetValue(trader.Id, out var stats))
                    {
                        <div>
                            <div>
                                <span>@stats.TotalTrades</span>
                                <span>交易次数</span>
                            </div>
                            <div>
                                <span>@stats.WinRate%</span>
                                <span>胜率</span>
                            </div>
                            <div>
                                <span>@stats.ProfitLossRatio.ToString("F2")</span>
                                <span>盈亏比</span>
                            </div>
                            <div>
                                <span>@stats.SharpeRatio.ToString("F2")</span>
                                <span>夏普率</span>
                            </div>
                        </div>
                    }

                    <div>
                        <FluentButton OnClick="@(() => Navigation.NavigateTo($"/traders/{trader.Id}/strategies"))">策略部署</FluentButton>
                        <FluentButton OnClick="@(() => Navigation.NavigateTo($"/traders/{trader.Id}/positions"))">持仓</FluentButton>
                        <FluentButton OnClick="@(() => Navigation.NavigateTo($"/traders/{trader.Id}/orders"))">订单</FluentButton>
                    </div>
                </FluentCard>
            }
        </div>
    }
</section>

<FluentDialog @ref="formDialog" Modal="true">
    <FluentDialogBody>
        <TitleTemplate>
            @(isEdit ? "编辑交易员" : "新建交易员")
        </TitleTemplate>
        <ChildContent>
            <div>
                <FluentAvatar Initials="@(string.IsNullOrWhiteSpace(formName) ? "?" : formName[..1].ToUpperInvariant())" />
                <div>
                    <FluentText As="TextTag.Paragraph" Weight="TextWeight.Semibold">@(string.IsNullOrWhiteSpace(formName) ? "新交易员" : formName)</FluentText>
                    <FluentText Size="TextSize.Size200">设置名称和头像</FluentText>
                </div>
            </div>

            <div>
                <FluentTextInput Width="100%" Size="TextInputSize.Large" Label="名称" Placeholder="输入交易员名称" @bind-Value="formName" />

                <FluentSelect TOption="string" TValue="string"
                    Width="100%"
                    Label="交易风格"
                    Items="styleOptions"
                    @bind-Value="formStyle" />

                @if (!string.IsNullOrWhiteSpace(formError))
                {
                    <FluentText As="TextTag.Paragraph">@formError</FluentText>
                }
            </div>
        </ChildContent>
        <ActionTemplate>
            <div>
                <FluentButton Appearance="ButtonAppearance.Primary" Disabled="@saving" OnClick="SaveAsync">
                    @(saving ? "保存中..." : "保存")
                </FluentButton>
                <FluentButton Appearance="ButtonAppearance.Outline" OnClick="CloseFormAsync">取消</FluentButton>
            </div>
        </ActionTemplate>
    </FluentDialogBody>
</FluentDialog>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<TraderItem> traders = [];
    private Dictionary<Guid, TraderStatsView> traderStats = [];
    private FluentDialog formDialog = default!;
    private bool loading = true;
    private bool saving;
    private bool isEdit;
    private Guid? editId;
    private string formName = string.Empty;
    private string formStyle = string.Empty;
    private string formAvatarColor = string.Empty;
    private string? formError;

    private static readonly string[] AvatarPalette =
    [
        "#4f7ec9", "#528a60", "#b8893a", "#bf4848",
        "#7c6eb0", "#c97b4a", "#4a9ea0", "#b06e8a"
    ];

    private static readonly string[] styleOptions =
    [
        "稳健型", "激进型", "平衡型", "灵活型"
    ];


    protected override async Task OnInitializedAsync()
    {
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        loading = true;
        try
        {
            var state = await AuthenticationStateTask;
            traders = (await TraderService.GetAllAsync(state.User)).ToList();

            foreach (var trader in traders)
            {
                try
                {
                    var stats = await TraderService.GetStatsAsync(trader.Id);
                    traderStats[trader.Id] = stats;
                }
                catch
                {
                    // 单个交易员统计加载失败不阻断页面
                }
            }
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OpenCreate()
    {
        isEdit = false;
        editId = null;
        formName = string.Empty;
        formStyle = string.Empty;
        formAvatarColor = AvatarPalette[Random.Shared.Next(AvatarPalette.Length)];
        formError = null;
        await formDialog.ShowAsync();
    }

    private async Task OpenEdit(TraderItem trader)
    {
        isEdit = true;
        editId = trader.Id;
        formName = trader.Name;
        formStyle = trader.Style ?? string.Empty;
        formAvatarColor = trader.AvatarColor ?? GetAvatarColorFromName(trader.Name);
        formError = null;
        await formDialog.ShowAsync();
    }

    private async Task CloseFormAsync()
    {
        await formDialog.HideAsync();
    }

    private async Task SaveAsync()
    {
        formError = null;
        saving = true;
        try
        {
            var state = await AuthenticationStateTask;

            if (isEdit && editId.HasValue)
            {
                await TraderService.UpdateAsync(editId.Value, new TraderFormModel
                {
                    Name = formName,
                    Style = string.IsNullOrWhiteSpace(formStyle) ? null : formStyle,
                    AvatarColor = formAvatarColor
                });
            }
            else
            {
                await TraderService.CreateAsync(state.User, new TraderFormModel
                {
                    Name = formName,
                    Style = string.IsNullOrWhiteSpace(formStyle) ? null : formStyle,
                    AvatarColor = formAvatarColor
                });
            }

            await formDialog.HideAsync();
            await ShowSuccess(isEdit ? "交易员已更新" : "交易员已创建");
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ToggleStatusAsync(Guid id, bool enable)
    {
        try
        {
            await TraderService.ToggleAsync(id, enable);
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            await ShowError($"切换失败: {ex.Message}");
        }
    }

    private static string GetAvatarColorFromName(string name)
    {
        var hash = 0;
        foreach (var c in name)
            hash = c + ((hash << 5) - hash);
        return AvatarPalette[Math.Abs(hash) % AvatarPalette.Length];
    }

    private static string GetStatusLabel(TraderStatus status) => status switch
    {
        TraderStatus.Active => "在岗",
        TraderStatus.Disabled => "离岗",
        TraderStatus.Deleted => "已删除",
        _ => status.ToString()
    };

    private async Task ShowSuccess(string text)
        => await ToastService.ShowToastAsync(o => { o.Body = text; o.Intent = ToastIntent.Success; o.Timeout = 3000; });

    private async Task ShowError(string text)
        => await ToastService.ShowToastAsync(o => { o.Body = text; o.Intent = ToastIntent.Error; });
}
