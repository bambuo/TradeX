@page "/audit-logs"
@inject AuditLogPageService AuditLogService
@inject IToastService ToastService

<PageTitle>审计日志</PageTitle>

<section class="audit-page">
    <header class="page-header">
        <FluentText As="TextTag.H2">审计日志</FluentText>
        <FluentSelect TOption="string" TValue="string" Width="180px"
            Items="resourceTypes" Placeholder="全部类型"
            @bind-Value="filterResourceType"
            @bind-Value:after="ReloadAsync" />
    </header>

    <FluentDataGrid ItemsProvider="@dataProvider" Pagination="@pagination" Class="audit-grid" Virtualize="false">
        <PropertyColumn Property="@(e => e.Timestamp)" Title="时间" Format="yyyy-MM-dd HH:mm:ss" />
        <PropertyColumn Property="@(e => e.Action)" Title="操作" />
        <PropertyColumn Property="@(e => e.Resource)" Title="资源" />
        <TemplateColumn Title="详情">
            <FluentButton Size="ButtonSize.Small" Appearance="ButtonAppearance.Outline" OnClick="@(() => OpenDetail(context))">查看</FluentButton>
        </TemplateColumn>
    </FluentDataGrid>
    <FluentPaginator State="@pagination" />
</section>

<FluentDialog @ref="detailDialog" Modal="true">
    <FluentDialogBody>
        <TitleTemplate>审计详情</TitleTemplate>
        <ChildContent>
            <div class="audit-detail">
                <div class="detail-row">
                    <span class="detail-label">操作</span>
                    <span class="detail-value">@detailAction</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">资源</span>
                    <span class="detail-value">@detailResource</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">IP 地址</span>
                    <span class="detail-value">@detailIp</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">用户 ID</span>
                    <span class="detail-value">@detailUserId</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">时间</span>
                    <span class="detail-value">@detailTime</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(detailJson))
                {
                    <div class="detail-section">
                        <FluentText Color="Color.Custom" CustomColor="var(--tx-muted)" Size="TextSize.Size200" Weight="TextWeight.Semibold">原始数据</FluentText>
                        <pre class="detail-json">@detailJson</pre>
                    </div>
                }
            </div>
        </ChildContent>
        <ActionTemplate>
            <div class="dialog-actions">
                <FluentButton Appearance="ButtonAppearance.Outline" OnClick="CloseDetailAsync">关闭</FluentButton>
            </div>
        </ActionTemplate>
    </FluentDialogBody>
</FluentDialog>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private FluentDialog detailDialog = default!;
    private PaginationState pagination = new() { ItemsPerPage = 15 };
    private string? filterResourceType;

    private string detailAction = string.Empty;
    private string detailResource = string.Empty;
    private string detailIp = string.Empty;
    private string detailUserId = string.Empty;
    private string detailTime = string.Empty;
    private string? detailJson;

    private static readonly string[] resourceTypes =
    [
        "交易员", "策略", "策略部署", "启用策略", "禁用策略", "交易所",
        "测试连接", "手动下单", "登录", "登出", "MFA设置", "MFA验证", "回测"
    ];

    private GridItemsProvider<AuditLogEntryView> dataProvider = default!;

    protected override void OnInitialized()
    {
        dataProvider = async request =>
        {
            try
            {
                var page = (request.StartIndex / pagination.ItemsPerPage) + 1;
                var (items, total) = await AuditLogService.GetPagedAsync(
                    page, pagination.ItemsPerPage, null, null, filterResourceType, null, null);

                return GridItemsProviderResult.From<AuditLogEntryView>(items.ToList(), total);
            }
            catch (Exception ex)
            {
                await ShowError(ex.Message);
                return GridItemsProviderResult.From<AuditLogEntryView>([], 0);
            }
        };
    }

    private async Task ReloadAsync()
    {
        await pagination.SetCurrentPageIndexAsync(0);
    }

    private async Task OpenDetail(AuditLogEntryView entry)
    {
        detailAction = entry.Action;
        detailResource = entry.Resource;
        detailIp = entry.IpAddress;
        detailUserId = entry.UserId?.ToString() ?? "-";
        detailTime = entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss");
        detailJson = entry.Detail;
        await detailDialog.ShowAsync();
    }

    private async Task CloseDetailAsync()
    {
        await detailDialog.HideAsync();
    }

    private async Task ShowError(string text)
        => await ToastService.ShowToastAsync(o => { o.Body = text; o.Intent = ToastIntent.Error; });
}
