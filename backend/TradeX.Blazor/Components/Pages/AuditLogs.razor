@page "/audit-logs"
@inject AuditLogPageService AuditLogService
@inject ToastService ToastService

<PageTitle>审计日志</PageTitle>

<section class="audit-page">
    <header class="page-header">
        <h2>审计日志</h2>
        <select class="form-select" style="width:180px" @bind="filterResourceType" @bind:after="ReloadAsync">
            <option value="">全部类型</option>
            @foreach (var rt in resourceTypes)
            {
                <option value="@rt">@rt</option>
            }
        </select>
    </header>

    <table class="table table-striped audit-grid">
        <thead>
            <tr>
                <th>时间</th>
                <th>操作</th>
                <th>资源</th>
                <th>详情</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in pagedData)
            {
                <tr>
                    <td>@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@entry.Action</td>
                    <td>@entry.Resource</td>
                    <td>
                        <Button Size="Size.Small" Color="Color.Secondary" OnClick="@(() => OpenDetail(entry))">查看</Button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination">
            <li class="page-item @(currentPage == 0 ? "disabled" : "")">
                <button class="page-link" @onclick="() => ChangePageAsync(0)">«</button>
            </li>
            @for (var i = 0; i < pageCount; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <button class="page-link" @onclick="() => ChangePageAsync(i)">@(i + 1)</button>
                </li>
            }
            <li class="page-item @(currentPage >= pageCount - 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => ChangePageAsync(pageCount - 1)">»</button>
            </li>
        </ul>
    </nav>
</section>

@if (showDetailDialog)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">审计详情</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetailAsync"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-sm table-borderless">
                        <tbody>
                            <tr>
                                <td class="fw-semibold" style="width:80px">操作</td>
                                <td>@detailAction</td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">资源</td>
                                <td>@detailResource</td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">IP 地址</td>
                                <td>@detailIp</td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">用户 ID</td>
                                <td>@detailUserId</td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">时间</td>
                                <td>@detailTime</td>
                            </tr>
                        </tbody>
                    </table>
                    @if (!string.IsNullOrWhiteSpace(detailJson))
                    {
                        <div>
                            <strong class="small">原始数据</strong>
                            <pre class="bg-light p-2 rounded mt-1"><code>@detailJson</code></pre>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <Button Color="Color.Secondary" OnClick="CloseDetailAsync">关闭</Button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<AuditLogEntryView> allData = [];
    private List<AuditLogEntryView> pagedData = [];
    private string? filterResourceType;
    private int currentPage;
    private int pageCount;
    private const int PageSize = 15;

    private bool showDetailDialog;
    private string detailAction = string.Empty;
    private string detailResource = string.Empty;
    private string detailIp = string.Empty;
    private string detailUserId = string.Empty;
    private string detailTime = string.Empty;
    private string? detailJson;

    private static readonly string[] resourceTypes =
    [
        "交易员", "策略", "策略部署", "启用策略", "禁用策略", "交易所",
        "测试连接", "手动下单", "登录", "登出", "MFA设置", "MFA验证", "回测"
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var (items, total) = await AuditLogService.GetPagedAsync(
                1, int.MaxValue, null, null, filterResourceType, null, null);
            allData = items.ToList();
            pageCount = (int)Math.Ceiling((double)allData.Count / PageSize);
            if (pageCount == 0) pageCount = 1;
            currentPage = 0;
            ApplyPaging();
        }
        catch (Exception ex)
        {
            await ShowError(ex.Message);
        }
    }

    private void ApplyPaging()
    {
        pagedData = allData
            .Skip(currentPage * PageSize)
            .Take(PageSize)
            .ToList();
    }

    private async Task ChangePageAsync(int page)
    {
        currentPage = page;
        ApplyPaging();
    }

    private async Task ReloadAsync()
    {
        currentPage = 0;
        await LoadDataAsync();
    }

    private async Task OpenDetail(AuditLogEntryView entry)
    {
        detailAction = entry.Action;
        detailResource = entry.Resource;
        detailIp = entry.IpAddress;
        detailUserId = entry.UserId?.ToString() ?? "-";
        detailTime = entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss");
        detailJson = entry.Detail;
        showDetailDialog = true;
    }

    private async Task CloseDetailAsync()
    {
        showDetailDialog = false;
    }

    private async Task ShowError(string text)
        => await ToastService.Error("错误", text);
}
