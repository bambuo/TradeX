{
  "name": "MACD 趋势策略",
  "description": "基于 MACD_LINE 零轴判断的趋势策略。MACD_LINE 上穿零轴入场，RSI 超买出场",
  "notes": [
    "MACD_LINE > 0 表示短期趋势向上，此时入场做多；MACD_LINE < 0 表示趋势转弱",
    "signal_gate 确保 MACD_LINE 在零轴上方才放行",
    "signal_action 直接读取信号管线中的 MACD_LINE、RSI 信号值",
    "出场用 RSI > 75 超买信号，避免趋势逆转后继续持仓"
  ],
  "chains": [
    {
      "key": "entry",
      "name": "入场链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "CLOSED" }, "priority": 1 },
        { "nodeKind": "signal_gate", "params": { "signal": "MACD_LINE", "op": ">", "threshold": 0 }, "priority": 2 },
        { "nodeKind": "fixed_size", "params": { "amount": 100, "currency": "USDT" }, "priority": 1 },
        { "nodeKind": "signal_action", "params": { "buySignal": "MACD_LINE", "sellSignal": "", "threshold": 0, "direction": "ABOVE" }, "priority": 1 },
        { "nodeKind": "max_drawdown", "params": { "maxDrawdownPercent": 3 }, "priority": 1 }
      ]
    },
    {
      "key": "exit",
      "name": "出场链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "OPEN" }, "priority": 1 },
        { "nodeKind": "signal_action", "params": { "buySignal": "", "sellSignal": "RSI", "threshold": 75, "direction": "ABOVE" }, "priority": 1 }
      ]
    }
  ]
}
