{
  "name": "双均线趋势策略",
  "description": "基于 SMA_20 趋势的 RSI 回调入场策略。SMA_20 上升趋势中 RSI 回调至 45 以下入场，RSI 超买至 75 以上出场",
  "notes": [
    "使用 signal_action 直接读取信号管线中的 SMA_20、RSI 信号，确保运行时可被触发",
    "signal_gate 提供阈值过滤，signal_action 提供触发逻辑，两者使用同一信号管线信号",
    "入场链 max_drawdown(3%) 防止回撤期开仓",
    "建议用于 1h~4h 级别，RSI 参数可调整"
  ],
  "chains": [
    {
      "key": "entry",
      "name": "入场链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "CLOSED" }, "priority": 1 },
        { "nodeKind": "signal_gate", "params": { "signal": "RSI", "op": "<", "threshold": 65 }, "priority": 2 },
        { "nodeKind": "fixed_size", "params": { "amount": 100, "currency": "USDT" }, "priority": 1 },
        { "nodeKind": "signal_action", "params": { "buySignal": "RSI", "sellSignal": "", "threshold": 45, "direction": "BELOW" }, "priority": 1 },
        { "nodeKind": "max_drawdown", "params": { "maxDrawdownPercent": 3 }, "priority": 1 },
        { "nodeKind": "max_pyramiding", "params": { "maxLevel": 1 }, "priority": 2 }
      ]
    },
    {
      "key": "exit",
      "name": "出场链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "OPEN" }, "priority": 1 },
        { "nodeKind": "signal_action", "params": { "buySignal": "", "sellSignal": "RSI", "threshold": 75, "direction": "ABOVE" }, "priority": 1 }
      ]
    }
  ]
}
