{
  "name": "波动率突破策略",
  "description": "市场波动放大时顺势而为。RANGE_PCT >= 1.5 确认波动放大且均线多头排列时入场，亏损达限离场",
  "notes": [
    "RANGE_PCT、RSI、SMA_20 均为信号管线中已注册的原生信号，signal_action 可直接读取",
    "signal_gate(RANGE_PCT>=1.5) + signal_gate(RSI>40) 双重过滤假突破",
    "signal_action 的 sellSignal 使用 RSI>80 作为出场条件",
    "max_drawdown(2.5%)、daily_loss_limit(200)、consecutive_loss_stop(3) 均在入场链保护新开仓"
  ],
  "chains": [
    {
      "key": "entry",
      "name": "入场链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "CLOSED" }, "priority": 1 },
        { "nodeKind": "signal_gate", "params": { "signal": "RANGE_PCT", "op": ">=", "threshold": 1.5 }, "priority": 2 },
        { "nodeKind": "signal_gate", "params": { "signal": "RSI", "op": ">", "threshold": 40 }, "priority": 3 },
        { "nodeKind": "fixed_size", "params": { "amount": 100, "currency": "USDT" }, "priority": 1 },
        { "nodeKind": "signal_action", "params": { "buySignal": "RANGE_PCT", "sellSignal": "", "threshold": 1.5, "direction": "ABOVE" }, "priority": 1 },
        { "nodeKind": "max_drawdown", "params": { "maxDrawdownPercent": 2.5 }, "priority": 1 },
        { "nodeKind": "daily_loss_limit", "params": { "maxDailyLoss": 200 }, "priority": 2 },
        { "nodeKind": "consecutive_loss_stop", "params": { "maxConsecutiveLosses": 3 }, "priority": 3 }
      ]
    },
    {
      "key": "exit",
      "name": "出场链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "OPEN" }, "priority": 1 },
        { "nodeKind": "signal_action", "params": { "buySignal": "", "sellSignal": "RSI", "threshold": 80, "direction": "ABOVE" }, "priority": 1 }
      ]
    }
  ]
}
