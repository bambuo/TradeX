{
  "name": "马丁格尔策略",
  "description": "经典马丁格尔仓位管理。RSI < 40 回调入场，价格每偏离均价 -2% 线性加仓，偏离 +3% 全平获利",
  "notes": [
    "RSI、DEVIATION_FROM_AVG 均为信号管线已注册的原生信号，signal_action 可直接读取",
    "首仓链：RSI < 40 时 signal_action 触发 BUY",
    "加仓链：偏离均价 -2% 时 pyramiding_size 计算仓位 + signal_action 触发 BUY，max_pyramiding(4) 限制层数",
    "出场链：偏离均价 +3% 时 signal_action 触发 SELL 全平获利",
    "马丁格尔风险极高，建议只用于 BTC/ETH 等流动性好的标的"
  ],
  "chains": [
    {
      "key": "entry",
      "name": "首仓链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "CLOSED" }, "priority": 1 },
        { "nodeKind": "signal_gate", "params": { "signal": "RSI", "op": "<", "threshold": 40 }, "priority": 2 },
        { "nodeKind": "fixed_size", "params": { "amount": 100, "currency": "USDT" }, "priority": 1 },
        { "nodeKind": "signal_action", "params": { "buySignal": "RSI", "sellSignal": "", "threshold": 40, "direction": "BELOW" }, "priority": 1 },
        { "nodeKind": "max_drawdown", "params": { "maxDrawdownPercent": 5 }, "priority": 1 }
      ]
    },
    {
      "key": "add_position",
      "name": "加仓链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "OPEN" }, "priority": 1 },
        { "nodeKind": "signal_gate", "params": { "signal": "DEVIATION_FROM_AVG", "op": "<=", "threshold": -2 }, "priority": 2 },
        { "nodeKind": "pyramiding_size", "params": { "baseAmount": 100, "multiplier": 1, "maxLevel": 4 }, "priority": 1 },
        { "nodeKind": "signal_action", "params": { "buySignal": "DEVIATION_FROM_AVG", "sellSignal": "", "threshold": -2, "direction": "BELOW" }, "priority": 1 },
        { "nodeKind": "max_pyramiding", "params": { "maxLevel": 4 }, "priority": 1 }
      ]
    },
    {
      "key": "exit",
      "name": "出场链",
      "schemaVersion": 1,
      "nodes": [
        { "nodeKind": "position_gate", "params": { "require": "OPEN" }, "priority": 1 },
        { "nodeKind": "signal_gate", "params": { "signal": "DEVIATION_FROM_AVG", "op": ">=", "threshold": 3 }, "priority": 2 },
        { "nodeKind": "signal_action", "params": { "buySignal": "", "sellSignal": "DEVIATION_FROM_AVG", "threshold": 3, "direction": "ABOVE" }, "priority": 1 }
      ]
    }
  ]
}
